# Application
APP_NAME=AI Assistant API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_assistant

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Database
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# ===== LLM CONFIGURATION =====

# Google Gemini (Primary LLM)
GOOGLE_API_KEY=your_google_gemini_api_key_here
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash-exp
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Groq (Fallback LLM)
GROQ_API_KEY=your_groq_api_key_here
FALLBACK_LLM_PROVIDER=groq
FALLBACK_LLM_MODEL=llama-3.1-70b-versatile

# ===== EMBEDDING CONFIGURATION =====

# AWS Bedrock (Primary - Nova 2 Multimodal)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MAX_TOKENS=8172

# Sentence Transformers (Fallback)
FALLBACK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FALLBACK_EMBEDDING_DIMENSIONS=384

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STUDENT=100
RATE_LIMIT_TEACHER=500
RATE_LIMIT_ADMIN=10000

# Resilience
CIRCUIT_BREAKER_ENABLED=true
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2

# Connection Pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
QDRANT_POOL_SIZE=10
REDIS_POOL_SIZE=50

# Data Retention (GDPR)
DATA_RETENTION_DAYS=90
SOFT_DELETE_RETENTION_DAYS=7

# Fallback
FALLBACK_ENABLED=true
CACHE_FALLBACK_TTL=3600

# Token Budget Management
TOKEN_BUDGET_ENABLED=true
TOKEN_BUDGET_STUDENT=50000
TOKEN_BUDGET_TEACHER=200000
TOKEN_BUDGET_ADMIN=1000000
TOKEN_BUDGET_PREMIUM=500000
TOKEN_BUDGET_FREE=10000
TOKEN_BUDGET_SOFT_THRESHOLD=0.8

# Anomaly Detection
ANOMALY_DETECTION_ENABLED=true
ANOMALY_SPIKE_THRESHOLD_SIGMA=3.0
ANOMALY_RAPID_FIRE_THRESHOLD=10
ANOMALY_COST_SPIKE_MULTIPLIER=5.0
ANOMALY_TOKEN_SPIKE_MULTIPLIER=5.0
ANOMALY_ALERT_EMAIL=admin@example.com

# Advanced RAG
HYBRID_SEARCH_ALPHA=0.5
RERANKING_ENABLED=true
HALLUCINATION_DETECTION_ENABLED=true
PII_MASKING_ENABLED=true
QUERY_REFORMULATION_ENABLED=true
ADAPTIVE_ROUTING_ENABLED=true
MULTIHOP_RETRIEVAL_ENABLED=true
BIAS_DETECTION_ENABLED=true
SECURE_RETRIEVAL_ENABLED=true
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL=300
CONTEXT_MAX_TOKENS=4000
PERFORMANCE_MONITORING_ENABLED=true

# Hierarchical Chunking (for Python 3.14 Documentation)
ENABLE_HIERARCHICAL_CHUNKING=true
PARENT_CHUNK_SIZE=2000
CHILD_CHUNK_SIZE=500
PARENT_OVERLAP=200
CHILD_OVERLAP=50

# Security
PROMPT_INJECTION_DETECTION_ENABLED=true
DOMAIN_CLASSIFICATION_ENABLED=true
DOMAIN_DESCRIPTION="Educational content from NCERT curriculum (Science, Math, Social Studies)"
INJECTION_BLOCK_THRESHOLD=0.7
DOMAIN_CONFIDENCE_THRESHOLD=0.7

# Monitoring
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=production

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Feature Flags
ENABLE_CHAT_HISTORY=true
ENABLE_FILE_UPLOAD=true
ENABLE_VOICE_INPUT=false
ENABLE_IMAGE_PROCESSING=true
